double tensao_radicular() 
{
    float TR, AR, A, cR;

    printf("=== Calculadora de Tensão Radicular ===\n\n");

    // Entrada de dados
    printf("Digite TR (Resistencia a tração das raízes): \n");
    scanf("%f", &TR);

    printf("Digite AR (Area das raízes): \n");
    scanf("%f", &AR);

    printf("Digite A (Area total do solo): \n");
    scanf("%f", &A);

    // Verificacao
    if (A == 0) 
    {
        printf("\nErro: A área total do solo não pode ser zero.\n");
        return 1;
    }
    // Calculo
    cR = TR * (AR / A);

    // Resultado
    printf("\nResultado:\n");
    printf("DeltaT = cR = %.4f kPa\n", cR);

    return cR;
}


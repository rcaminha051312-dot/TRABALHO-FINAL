}

double tensao_radicular() 
{
    float TR, AR, A, cR;

    printf("=== Calculadora de Tensão Radicular ===\n\n");

    // Entrada de dados
    printf("Digite TR (Resistencia a tração das raízes): \n");
    scanf("%f", &TR);

    printf("Digite AR (Area das raízes): \n");
    scanf("%f", &AR);

    printf("Digite A (Area total do solo): \n");
    scanf("%f", &A);

    // Verificacao
    if (A == 0) 
    {
        printf("\nErro: A área total do solo não pode ser zero.\n");
        return 1;
    }
    // Calculo
    cR = TR * (AR / A);

    // Resultado
    printf("\nResultado:\n");
    printf("DeltaT = cR = %.4f kPa\n", cR);

    return cR;
}
double balanco_de_massa()
{
    float entrada, saida, geracao, consumo, acumulo;
    printf("Digite qual a entrada de material: \n");
    scanf("%f", &entrada);
    printf("Digite qual a saida de material: \n");
    scanf("%f", &saida);
    printf("Digite qual a geração de material: \n");
    scanf("%f", &geracao);
    printf("Digite qual o consumo de material: \n");
    scanf("%f", &consumo);
    acumulo = entrada - saida + geracao - consumo;

    printf("O acumulo de material é: %.4f", acumulo);
    return(acumulo);
}
double numero_de_reynolds()
{
    float p, v, d, u, Re;
    printf("Digite qual a massa especifica do fluido: \n");
    scanf("%f", &p);
    printf("Digite qual a velocidade de escoamento: \n");
    scanf("%f", &v);
    printf("Digite qual o diametro da tubulação: \n");
    scanf("%f", &d);
    printf("Digite qual a viscosidade do fluido: \n");
    scanf("%f", &u);

    Re = (p * v * d) / u;

    printf("O numero de Reynolds é: %.4f", Re);
    return(Re);
}

